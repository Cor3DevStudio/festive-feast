# Supabase (Dashboard → Project Settings → API)
# Frontend uses anon key only. Never use service_role in client-side code.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Production: set this on Vercel so sign-up confirmation emails use your domain (not localhost).
# Supabase Dashboard → Authentication → URL Configuration must use the same https origin.
# VITE_SITE_URL=https://christmasdecors.com.ph

# Server-only: seed scripts (seed-test-accounts.mjs, seed-products.mjs) and local Vite QR check proxy
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PayMongo — set as a Supabase Edge Function secret (NOT in .env for client):
# supabase secrets set PAYMONGO_SECRET_KEY=sk_live_XXXXXXXX
# QR Ph (qrph) only works with LIVE keys, not test keys.

# Order confirmation — Gmail SMTP (Vercel api/send-order-confirmation + local Vite dev proxy):
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx   # Google Account → App Passwords (not your normal password)
# Optional: STORE_NAME="Christmas Decors PH"  SITE_PUBLIC_URL=https://your-site.com
