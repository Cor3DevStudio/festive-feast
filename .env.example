# Supabase (Dashboard → Project Settings → API)
# Frontend uses anon key only. Never use service_role in client-side code.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: canonical public URL for signup confirmation emails (emailRedirectTo).
# If omitted, the browser origin at signup time is used (correct when users register on prod).
# VITE_SITE_URL=https://your-deployed-domain.example

# Server-only: seed scripts (seed-test-accounts.mjs, seed-products.mjs) and local Vite QR check proxy
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PayMongo — set as a Supabase Edge Function secret (NOT in .env for client):
# supabase secrets set PAYMONGO_SECRET_KEY=sk_live_XXXXXXXX
# QR Ph (qrph) only works with LIVE keys, not test keys.
